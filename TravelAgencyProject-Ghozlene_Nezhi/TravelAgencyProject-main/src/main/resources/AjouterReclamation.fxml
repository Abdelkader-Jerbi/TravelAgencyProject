<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AjouterReclamation"
            prefWidth="800.0" prefHeight="500.0">

    <!-- Menu latéral -->
    <left>
        <VBox spacing="20.0" alignment="TOP_CENTER" prefWidth="200.0" style="-fx-background-color: #2C3E50;">
            <children>
                <Label text="Menu" style="-fx-text-fill: white; -fx-font-size: 16px;" />
                <Button text="Home" maxWidth="180" style="-fx-background-color: #34495E; -fx-text-fill: white;" />
                <Button text="Consulter Réclamations" maxWidth="180" style="-fx-background-color: #34495E; -fx-text-fill: white;" />
                <Button text="Réservation Hôtel" maxWidth="180" style="-fx-background-color: #34495E; -fx-text-fill: white;" />
            </children>
            <padding>
                <Insets top="20" left="10" right="10" bottom="20"/>
            </padding>
        </VBox>
    </left>

    <!-- Contenu principal -->
    <center>
        <VBox alignment="CENTER" spacing="15.0" style="-fx-padding: 30;">
            <children>
                <Label text="Ajouter une Réclamation" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <TextField fx:id="idReclamationTF" promptText="ID Réclamation" />
                <TextField fx:id="idUserTF" promptText="ID Utilisateur" />
                <TextField fx:id="categorieTF" promptText="Catégorie" />
                <TextField fx:id="dateTF" promptText="Date (YYYY-MM-DD)" />
                <TextArea fx:id="commentaireTF" promptText="Commentaire" prefRowCount="3" wrapText="true" />
                <HBox spacing="10">
                    <children>
                        <Button text="Ajouter Réclamation" onAction="#ajouterReclamation" />
                        <Button text="Annuler" onAction="#annulerReclamation" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>

</BorderPane>